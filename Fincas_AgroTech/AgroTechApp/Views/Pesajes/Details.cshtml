@model AgroTechApp.Models.DB.Pesaje

@{
    ViewData["Title"] = "Detalles del Pesaje";
    var primaryColor = "#2E8B57";
    var secondaryColor = "#F4A460";
    var accentColor = "#4cc9f0";

    var historialPesajes = ViewBag.HistorialPesajes as List<AgroTechApp.Models.DB.Pesaje> ?? new List<AgroTechApp.Models.DB.Pesaje>();
}

<style>
    /* ===== Scope: solo afecta al contenido de esta vista ===== */

    .pesaje-page {
        --primary: #2E8B57;
        --primary-dark: #26734d;
        --secondary: #F4A460;
        --accent: #4cc9f0;
        --success: #28a745;
        --warning: #f59e0b;
        --danger: #ef4444;
        --dark: #1e293b;
        --light: #f8fafc;
        --gray: #64748b;
        --border: #e2e8f0;
        padding: 20px;
        color: var(--dark);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .pesaje-card {
        max-width: 1400px;
        margin: 0 auto;
        background: white;
        border-radius: 20px;
        box-shadow: 0 20px 40px rgba(0,0,0,.1);
        overflow: hidden;
        animation: pz-fadeIn .6s ease-out;
    }

    @@keyframes pz-fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ---- Header ---- */
    .pz-header {
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        color: white;
        padding: 2.5rem;
        position: relative;
        overflow: hidden;
    }

    .pz-header-content {
        position: relative;
        z-index: 2;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1.5rem;
    }

    .pz-header-text h1 {
        font-size: 2.2rem;
        font-weight: 700;
        margin-bottom: .5rem;
    }

    .pz-header-text p {
        font-size: 1.1rem;
        opacity: .9;
    }

    .pz-back-btn {
        background: rgba(255,255,255,.2);
        color: white;
        border: 2px solid rgba(255,255,255,.3);
        padding: .875rem 1.5rem;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        transition: all .3s;
    }

        .pz-back-btn:hover {
            background: rgba(255,255,255,.3);
            color: white;
            transform: translateX(-5px);
        }

    /* ---- Stats ---- */
    .pz-stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px,1fr));
        gap: 1.5rem;
        padding: 2rem;
        background: var(--light);
        border-bottom: 1px solid var(--border);
    }

    .pz-stat-card {
        background: white;
        border-radius: 12px;
        padding: 1.5rem;
        border-left: 4px solid var(--primary);
        box-shadow: 0 2px 8px rgba(0,0,0,.05);
    }

    .pz-stat-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .pz-stat-icon {
        width: 50px;
        height: 50px;
        border-radius: 12px;
        background: linear-gradient(135deg, var(--primary), var(--accent));
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.5rem;
        flex-shrink: 0;
    }

    .pz-stat-value {
        font-size: 2rem;
        font-weight: 800;
        color: var(--primary);
        margin-bottom: .25rem;
    }

    .pz-stat-label {
        color: var(--gray);
        font-size: .9rem;
        font-weight: 600;
    }

    .pz-stat-change {
        margin-top: .5rem;
        padding: .35rem .75rem;
        border-radius: 50px;
        font-size: .85rem;
        font-weight: 600;
        display: inline-block;
    }

        .pz-stat-change.positive {
            background: rgba(40,167,69,.15);
            color: var(--success);
        }

        .pz-stat-change.negative {
            background: rgba(239,68,68,.15);
            color: var(--danger);
        }

    /* ---- Tabs ---- */
    .pz-tabs-container {
        border-bottom: 1px solid var(--border);
    }

    .pz-tabs {
        display: flex;
        gap: 0;
        flex-wrap: wrap;
        padding: 0 2rem;
    }

    .pz-tab {
        padding: 1.25rem 2rem;
        cursor: pointer;
        font-weight: 600;
        color: var(--gray);
        border-bottom: 3px solid transparent;
        transition: all .3s;
        display: flex;
        align-items: center;
        gap: .75rem;
        user-select: none;
    }

        .pz-tab.active {
            color: var(--primary);
            border-bottom-color: var(--primary);
            background: rgba(46,139,87,.05);
        }

        .pz-tab:hover:not(.active) {
            color: var(--dark);
            background: var(--light);
        }

    /* ---- Tab content ---- */
    .pz-tab-content {
        display: none;
        padding: 2.5rem;
    }

        .pz-tab-content.active {
            display: block;
            animation: pz-fadeIn .4s ease-out;
        }

    /* ---- Panel interno ---- */
    .pz-panel {
        background: white;
        border-radius: 15px;
        padding: 2rem;
        margin-bottom: 2rem;
        border: 1px solid var(--border);
    }

    .pz-panel-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
    }

    .pz-panel-title {
        font-size: 1.3rem;
        font-weight: 600;
        color: var(--dark);
    }

    /* ---- Tabla historial ---- */
    .pz-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 1rem;
    }

        .pz-table th {
            background: var(--light);
            padding: 1rem;
            text-align: left;
            font-weight: 600;
            color: var(--dark);
            border-bottom: 2px solid var(--border);
        }

        .pz-table td {
            padding: 1rem;
            border-bottom: 1px solid var(--border);
        }

        .pz-table tbody tr:hover {
            background: rgba(46,139,87,.05);
        }

    .pz-peso-badge {
        background: linear-gradient(135deg, var(--primary), var(--accent));
        color: white;
        padding: .3rem .7rem;
        border-radius: 50px;
        font-weight: 600;
        font-size: .85rem;
        margin-left: .4rem;
    }

    .pz-ganancia {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        font-weight: 600;
    }

        .pz-ganancia.positiva {
            color: var(--success);
        }

        .pz-ganancia.negativa {
            color: var(--danger);
        }

    /* ---- Empty ---- */
    .pz-empty {
        text-align: center;
        padding: 3rem;
        color: var(--gray);
    }

        .pz-empty i {
            font-size: 4rem;
            margin-bottom: 1rem;
            opacity: .5;
            display: block;
        }

    /* ---- Footer de acciones ---- */
    .pz-footer {
        background: linear-gradient(135deg, #f8fafc, #eef2f7);
        border-top: 1px solid var(--border);
        padding: 1.5rem 2.5rem;
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .pz-btn {
        padding: .875rem 1.5rem;
        border: none;
        border-radius: 10px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        transition: all .3s;
        cursor: pointer;
        font-family: inherit;
    }

    .pz-btn-primary {
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        color: white;
    }

        .pz-btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(46,139,87,.4);
            color: white;
        }

    .pz-btn-secondary {
        background: white;
        color: var(--dark);
        border: 2px solid var(--border);
    }

        .pz-btn-secondary:hover {
            background: var(--dark);
            border-color: var(--dark);
            color: white;
        }

    /* ---- Responsive ---- */
    @@media(max-width:768px) {
        .pz-stats-grid {
            grid-template-columns: 1fr;
        }

        .pz-tabs {
            padding: 0;
            flex-direction: column;
        }

        .pz-tab-content {
            padding: 1.5rem;
        }

        .pz-table {
            font-size: .85rem;
        }

        .pz-footer {
            justify-content: center;
        }
    }
</style>

<div class="pesaje-page">
    <div class="pesaje-card">

        @* ===== HEADER ===== *@
        <div class="pz-header">
            <div class="pz-header-content">
                <div class="pz-header-text">
                    <h1>📊 Análisis de Pesaje</h1>
                    <p>Animal: @(Model.Animal?.Nombre ?? "Sin nombre") (@Model.Animal?.Arete)</p>
                </div>
                <a asp-action="Index" class="pz-back-btn">
                    <i class="fas fa-arrow-left"></i> Volver
                </a>
            </div>
        </div>

        @* ===== STATS ===== *@
        <div class="pz-stats-grid">

            @* Peso actual *@
            <div class="pz-stat-card">
                <div class="pz-stat-header">
                    <div class="pz-stat-icon"><i class="fas fa-weight-hanging"></i></div>
                </div>
                <div class="pz-stat-value">@Model.PesoKg kg</div>
                <div class="pz-stat-label">Peso Actual</div>
                @if (historialPesajes.Count > 1)
                {
                    var pesajeAnterior = historialPesajes.OrderByDescending(p => p.Fecha).Skip(1).FirstOrDefault();
                    if (pesajeAnterior != null)
                    {
                        var diferencia = Model.PesoKg - pesajeAnterior.PesoKg;
                        var clase = diferencia >= 0 ? "positive" : "negative";
                        var icono = diferencia >= 0 ? "▲" : "▼";
                        <span class="pz-stat-change @clase">@icono @Math.Abs(diferencia).ToString("0.0") kg</span>
                    }
                }
            </div>

            @* Ganancia total *@
            <div class="pz-stat-card">
                <div class="pz-stat-header">
                    <div class="pz-stat-icon" style="background:linear-gradient(135deg,#28a745,#22c55e)">
                        <i class="fas fa-chart-line"></i>
                    </div>
                </div>
                @if (historialPesajes.Count > 1)
                {
                    var primerPesaje = historialPesajes.OrderBy(p => p.Fecha).First();
                    var gananciaTotal = Model.PesoKg - primerPesaje.PesoKg;
                    <div class="pz-stat-value">@gananciaTotal.ToString("+0.0;-0.0") kg</div>
                    <div class="pz-stat-label">Ganancia Total</div>
                }
                else
                {
                    <div class="pz-stat-value">--</div>
                    <div class="pz-stat-label">Ganancia Total</div>
                }
            </div>

            @* GDP *@
            <div class="pz-stat-card">
                <div class="pz-stat-header">
                    <div class="pz-stat-icon" style="background:linear-gradient(135deg,#f59e0b,#fbbf24)">
                        <i class="fas fa-calendar-day"></i>
                    </div>
                </div>
                @if (historialPesajes.Count > 1)
                {
                    var primerPesaje = historialPesajes.OrderBy(p => p.Fecha).First();
                    var ultimoPesaje = historialPesajes.OrderByDescending(p => p.Fecha).First();
                    var diasTranscurridos = (ultimoPesaje.Fecha - primerPesaje.Fecha).Days;
                    var gdp = diasTranscurridos > 0 ? (ultimoPesaje.PesoKg - primerPesaje.PesoKg) / diasTranscurridos : 0;
                    <div class="pz-stat-value">@gdp.ToString("0.000")</div>
                    <div class="pz-stat-label">GDP (kg/día)</div>
                }
                else
                {
                    <div class="pz-stat-value">--</div>
                    <div class="pz-stat-label">GDP (kg/día)</div>
                }
            </div>

            @* Total pesajes *@
            <div class="pz-stat-card">
                <div class="pz-stat-header">
                    <div class="pz-stat-icon" style="background:linear-gradient(135deg,#4cc9f0,#06b6d4)">
                        <i class="fas fa-history"></i>
                    </div>
                </div>
                <div class="pz-stat-value">@historialPesajes.Count</div>
                <div class="pz-stat-label">Total Pesajes</div>
            </div>
        </div>

        @* ===== TABS ===== *@
        <div class="pz-tabs-container">
            <div class="pz-tabs">
                <div class="pz-tab active" data-pztab="pz-grafica">
                    <i class="fas fa-chart-area"></i> Gráfica de Evolución
                </div>
                <div class="pz-tab" data-pztab="pz-historial">
                    <i class="fas fa-history"></i> Historial Completo
                </div>
                <div class="pz-tab" data-pztab="pz-detalles">
                    <i class="fas fa-info-circle"></i> Detalles del Pesaje
                </div>
            </div>
        </div>

        @* ---- Tab: Gráfica ---- *@
        <div class="pz-tab-content active" id="pz-grafica">
            <div class="pz-panel">
                <div class="pz-panel-header">
                    <div class="pz-panel-title">📈 Evolución del Peso</div>
                </div>
                <canvas id="pesoChart" style="max-height:400px;"></canvas>
            </div>
        </div>

        @* ---- Tab: Historial ---- *@
        <div class="pz-tab-content" id="pz-historial">
            <div class="pz-panel">
                <div class="pz-panel-header">
                    <div class="pz-panel-title">📋 Historial de Pesajes</div>
                </div>
                @if (historialPesajes.Any())
                {
                    <table class="pz-table">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Peso (kg)</th>
                                <th>Ganancia</th>
                                <th>Días</th>
                                <th>GDP</th>
                                <th>Observaciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var pesajesOrdenados = historialPesajes.OrderByDescending(p => p.Fecha).ToList();
                                for (int i = 0; i < pesajesOrdenados.Count; i++)
                                {
                                    var pesaje = pesajesOrdenados[i];
                                    var esActual = pesaje.PesajeId == Model.PesajeId;

                                    decimal? ganancia = null;
                                    int? dias = null;
                                    decimal? gdp = null;

                                    if (i < pesajesOrdenados.Count - 1)
                                    {
                                        var pesajeAnterior = pesajesOrdenados[i + 1];
                                        ganancia = pesaje.PesoKg - pesajeAnterior.PesoKg;
                                        dias = (pesaje.Fecha - pesajeAnterior.Fecha).Days;
                                        gdp = dias > 0 ? ganancia / dias : 0;
                                    }

                                    <tr style="@(esActual ? "background:rgba(46,139,87,.1);" : "")">
                                        <td>
                                            @pesaje.Fecha.ToString("dd/MM/yyyy HH:mm")
                                            @if (esActual)
                                            {
                                                <span class="pz-peso-badge">Actual</span>
                                            }
                                        </td>
                                        <td><strong style="color:#2E8B57">@pesaje.PesoKg kg</strong></td>
                                        <td>
                                            @if (ganancia.HasValue)
                                            {
                                                var clase = ganancia >= 0 ? "positiva" : "negativa";
                                                var icono = ganancia >= 0 ? "▲" : "▼";
                                                <span class="pz-ganancia @clase">@icono @Math.Abs(ganancia.Value).ToString("0.0") kg</span>
                                            }
                                            else
                                            {
                                                <span style="color:#64748b">Primer pesaje</span>
                                            }
                                        </td>
                                        <td>@(dias?.ToString() ?? "--") días</td>
                                        <td>@(gdp.HasValue? gdp.Value.ToString("0.000") : "--") kg/día</td>
                                        <td>@(pesaje.Observacion ?? "-")</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="pz-empty">
                        <i class="fas fa-weight-hanging"></i>
                        <p>No hay historial de pesajes disponible</p>
                    </div>
                }
            </div>
        </div>

        @* ---- Tab: Detalles ---- *@
        <div class="pz-tab-content" id="pz-detalles">
            <div class="pz-panel">
                <div class="pz-panel-header">
                    <div class="pz-panel-title">ℹ️ Detalles del Pesaje Actual</div>
                </div>
                <table class="pz-table">
                    <tr><th style="width:200px">ID del Pesaje</th> <td>#@Model.PesajeId</td></tr>
                    <tr><th>Animal</th>          <td><strong>@Model.Animal?.Nombre</strong> (Arete: @Model.Animal?.Arete)</td></tr>
                    <tr><th>Fecha y Hora</th>    <td>@Model.Fecha.ToString("dd/MM/yyyy HH:mm")</td></tr>
                    <tr><th>Peso Registrado</th> <td><strong style="color:#2E8B57;font-size:1.2rem">@Model.PesoKg kg</strong></td></tr>
                    <tr><th>Observaciones</th>   <td>@(Model.Observacion ?? "Sin observaciones")</td></tr>
                </table>
            </div>
        </div>

        @* ===== FOOTER DE ACCIONES ===== *@
        <div class="pz-footer">
            <a asp-action="Edit" asp-route-id="@Model.PesajeId" class="pz-btn pz-btn-primary">
                <i class="fas fa-edit"></i> Editar Pesaje
            </a>
            <a asp-action="Index" class="pz-btn pz-btn-secondary">
                <i class="fas fa-arrow-left"></i> Volver al Listado
            </a>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Tabs
        document.querySelectorAll('.pz-tab').forEach(function(tab) {
            tab.addEventListener('click', function() {
                document.querySelectorAll('.pz-tab').forEach(function(t) { t.classList.remove('active'); });
                document.querySelectorAll('.pz-tab-content').forEach(function(c) { c.classList.remove('active'); });
                tab.classList.add('active');
                document.getElementById(tab.getAttribute('data-pztab')).classList.add('active');
            });
        });

        // Chart
        var ctx = document.getElementById('pesoChart').getContext('2d');
        var fechas = @Html.Raw(Json.Serialize(historialPesajes.OrderBy(p => p.Fecha).Select(p => p.Fecha.ToString("dd/MM")).ToList()));
        var pesos  = @Html.Raw(Json.Serialize(historialPesajes.OrderBy(p => p.Fecha).Select(p => p.PesoKg).ToList()));

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: fechas,
                datasets: [{
                    label: 'Peso (kg)',
                    data: pesos,
                    borderColor: '@primaryColor',
                    backgroundColor: 'rgba(46,139,87,0.1)',
                    borderWidth: 3,
                    fill: true,
                    tension: 0.4,
                    pointRadius: 6,
                    pointHoverRadius: 8
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: { display: true, position: 'top' },
                    tooltip: {
                        callbacks: {
                            label: function(context) { return 'Peso: ' + context.parsed.y + ' kg'; }
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: false,
                        ticks: { callback: function(value) { return value + ' kg'; } }
                    }
                }
            }
        });
    </script>
}
